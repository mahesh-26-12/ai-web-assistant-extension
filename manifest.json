{
  "manifest_version": 3,
  "name": "AI Summarizer",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  

  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": ["https://openrouter.ai/*"]
}